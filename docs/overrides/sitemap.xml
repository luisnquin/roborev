{#-
  Zensical only includes nav pages in the sitemap; keep the homepage indexed too.
-#}
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://roborev.io/</loc>
  </url>
  {%- for page in pages -%}
    {%- if page.canonical_url %}
      <url>
        <loc>{{ page.canonical_url }}</loc>
      </url>
    {%- endif -%}
  {%- endfor %}
</urlset>
